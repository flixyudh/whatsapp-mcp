# Address the HTTP/SSE server listens on inside the container/host.
HTTP_ADDR=:8080

# Externally reachable base URL for this server. MCP clients use this to build
# the SSE endpoint URL, e.g. https://wa-mcp.example.com -> .../sse
# Use your real domain in production (a reverse proxy handling TLS is recommended).
PUBLIC_BASE_URL=http://localhost:8080

# Where whatsmeow stores its session/device crypto material. Back this up;
# losing it means re-scanning the QR code.
WHATSAPP_DB_PATH=data/whatsapp.db

# Where chat/message history is stored for the MCP tools to query.
HISTORY_DB_PATH=data/history.db

# DEBUG, INFO, WARN, or ERROR
LOG_LEVEL=INFO

# Optional: require "Authorization: Bearer <token>" on every MCP request.
# Leave empty to disable (fine for local/private networks only).
MCP_AUTH_TOKEN=

# How many days of history WhatsApp's post-pairing sync should backfill.
HISTORY_SYNC_MAX_AGE_DAYS=90
