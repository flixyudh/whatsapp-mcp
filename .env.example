# Address the HTTP server listens on inside the container/host. Serves the
# MCP Streamable HTTP endpoint (/mcp), MCP SSE endpoint (/sse), and the REST
# API (/api/v1/...).
HTTP_ADDR=:8080

# Externally reachable base URL for this server. Used to build the SSE
# endpoint URL advertised to clients, e.g. https://wa-mcp.example.com ->
# .../sse. (The Streamable HTTP endpoint at /mcp doesn't need this.)
# Use your real domain in production (a reverse proxy handling TLS is recommended).
PUBLIC_BASE_URL=http://localhost:8080

# Where whatsmeow stores its session/device crypto material. Back this up;
# losing it means re-scanning the QR code.
WHATSAPP_DB_PATH=data/whatsapp.db

# Where chat/message history is stored for the MCP tools to query.
HISTORY_DB_PATH=data/history.db

# DEBUG, INFO, WARN, or ERROR
LOG_LEVEL=INFO

# Optional: require "Authorization: Bearer <token>" on every request to
# /mcp, /sse, and /api/v1/*. Leave empty to disable (fine for local/private
# networks only).
MCP_AUTH_TOKEN=

# How many days of history WhatsApp's post-pairing sync should backfill.
HISTORY_SYNC_MAX_AGE_DAYS=90

# Optional: POST a JSON payload to this URL for every incoming message
# (e.g. an n8n Webhook trigger node's URL). Leave empty to disable.
WEBHOOK_URL=

# Optional: only dispatch messages sent by these numbers (comma-separated,
# digits only or with +/-/spaces -- formatting is stripped automatically),
# e.g. "6281234567890,6289876543210". Leave empty to dispatch every
# incoming message.
WEBHOOK_FROM_NUMBERS=

# Optional: sign webhook payloads with HMAC-SHA256 in the
# X-Webhook-Signature header (format: "sha256=<hex>"), so the receiver can
# verify the request actually came from this server. Leave empty to disable.
WEBHOOK_SECRET=

# --- Everything above is read directly by the Go app (both `go run` and ---
# --- inside the whatsapp-mcp container via compose.yaml's `environment:`). ---
# --- Everything below is only used by `docker compose` itself, for the ---
# --- n8n service in compose.yaml (${VAR} substitution on the host side). ---

# Required by n8n: any random 32+ char string, generate once and keep it —
# rotating it makes n8n unable to decrypt previously saved credentials.
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Optional: timezone for n8n's scheduling, e.g. Asia/Jakarta
TZ=UTC

